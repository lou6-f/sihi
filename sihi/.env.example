# ═══════════════════════════════════════════════════════════════
# SiHi — Environment Variables Template
# Hướng dẫn: copy file này thành .env rồi điền giá trị của bạn
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ═══════════════════════════════════════
# Database — REQUIRED
# Khuyến nghị dùng Supabase (free): https://supabase.com
# Sau khi tạo project, vào Settings > Database > Connection string
# ═══════════════════════════════════════
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ═══════════════════════════════════════
# Authentication — REQUIRED
# Tạo secret: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# ═══════════════════════════════════════
NEXTAUTH_SECRET="<random-32-bytes>"
NEXTAUTH_URL="http://localhost:3000"

# ═══════════════════════════════════════
# WebSocket JWT — REQUIRED
# PHẢI khác NEXTAUTH_SECRET, tạo tương tự
# ═══════════════════════════════════════
WS_JWT_SECRET="<random-32-bytes-different-from-above>"
WS_JWT_EXPIRES_IN_SECONDS=300

# ═══════════════════════════════════════
# AI Provider — REQUIRED
# Lấy Gemini API key miễn phí: https://aistudio.google.com
# Có thể điền nhiều key cách nhau bởi dấu phẩy để tăng rate limit
# ═══════════════════════════════════════
AI_PROVIDER=gemini
GEMINI_API_KEYS="your-gemini-api-key-1,your-gemini-api-key-2"
GEMINI_MODEL="gemini-2.0-flash"
GEMINI_EMBEDDING_MODEL="gemini-embedding-001"
GEMINI_ROTATION_STRATEGY="round_robin"
GEMINI_MAX_RETRIES=1
GEMINI_COOLDOWN_SECONDS=600

# ═══════════════════════════════════════
# Email Provider
# Mặc định "mock" — OTP hiện ra terminal, không cần cấu hình
# Để gửi email thật: đổi sang "smtp" và điền thông tin Gmail bên dưới
# ═══════════════════════════════════════
EMAIL_PROVIDER=mock
EMAIL_FROM="SiHi <no-reply@sihi.vn>"

# Gmail SMTP (chỉ cần nếu EMAIL_PROVIDER=smtp)
# Hướng dẫn tạo App Password Gmail: https://myaccount.google.com/apppasswords
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-gmail-app-password"

# ═══════════════════════════════════════
# OTP — không cần thay đổi
# ═══════════════════════════════════════
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_RATE_LIMIT_SECONDS=60

# ═══════════════════════════════════════
# STT / TTS — không cần thay đổi
# PhoWhisper chạy qua Docker, fallback về Web Speech API
# ═══════════════════════════════════════
STT_PROVIDER=phowhisper
PHOWHISPER_URL=http://localhost:8001
TTS_PROVIDER=browser

# ═══════════════════════════════════════
# WebSocket — không cần thay đổi
# ═══════════════════════════════════════
NEXT_PUBLIC_WS_URL="ws://localhost:3001"
WS_PORT=3001

# ═══════════════════════════════════════
# File Storage — không cần thay đổi
# ═══════════════════════════════════════
UPLOAD_DIR="./data/uploads"
MAX_FILE_SIZE=5242880

# ═══════════════════════════════════════
# App URL — không cần thay đổi (local dev)
# ═══════════════════════════════════════
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_TTS_PROVIDER=browser
NEXT_PUBLIC_STT_FALLBACK=webspeech
