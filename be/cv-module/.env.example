# ═══════════════════════════════════════════════════════════════
# cv-module — Environment Variables Template
# Copy file này thành .env và điền giá trị
# ═══════════════════════════════════════════════════════════════

# PostgreSQL — dùng chung Supabase với SiHi (DIRECT_URL không có pgbouncer)
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<dbname>

# Gemini API — dùng cùng key với sihi/.env
GEMINI_API_KEY=<your_api_key_here>
GEMINI_MODEL=gemini-2.0-flash

# Redis — kết nối tới Redis container
REDIS_URL=redis://redis:6379

# MinerU
MINERU_MODEL_SOURCE=huggingface
MINERU_BACKEND=pipeline
MINERU_TIMEOUT_SECONDS=180
MINERU_WARMUP_ENABLED=true
MINERU_WARMUP_TIMEOUT_SECONDS=600

# App limits
MAX_FILE_SIZE_MB=10
MAX_QUESTIONS=20
TASK_TTL_SECONDS=3600
EVAL_MAX_RETRIES=3
EVAL_TIMEOUT_SECONDS=90

# Knowledge Graph
KG_ENABLED=true
KG_MODE=auto
KG_ARTIFACT_DIR=./data/tinix_kg
KG_TIMEOUT_SECONDS=10
