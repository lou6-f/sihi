# ═══════════════════════════════════════
# Database
# ═══════════════════════════════════════
DATABASE_URL="postgresql://user:password@host:5432/sihi?schema=public"

# ═══════════════════════════════════════
# Authentication (NextAuth v4)
# ═══════════════════════════════════════
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# ═══════════════════════════════════════
# WebSocket JWT (SEPARATE from NextAuth)
# ═══════════════════════════════════════
WS_JWT_SECRET="generate-different-secret-with-openssl-rand-base64-32"
WS_JWT_EXPIRES_IN_SECONDS=300

# ═══════════════════════════════════════
# AI Provider: gemini (MVP only)
# ═══════════════════════════════════════
AI_PROVIDER=gemini
GEMINI_API_KEYS="key_aaa,key_bbb,key_ccc"
GEMINI_MODEL="gemini-3.5-flash"
GEMINI_EMBEDDING_MODEL="text-embedding-004"
GEMINI_ROTATION_STRATEGY="round_robin"
GEMINI_MAX_RETRIES=3
GEMINI_COOLDOWN_SECONDS=600

# ═══════════════════════════════════════
# Email Provider: mock | resend | smtp
# ═══════════════════════════════════════
EMAIL_PROVIDER=mock
EMAIL_FROM="SiHi <no-reply@sihi.vn>"
# RESEND_API_KEY="re_xxxxx"
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_USER="your@gmail.com"
# SMTP_PASS="app-password"

# ═══════════════════════════════════════
# OTP
# ═══════════════════════════════════════
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_RATE_LIMIT_SECONDS=60

# ═══════════════════════════════════════
# STT / TTS
# ═══════════════════════════════════════
STT_PROVIDER=phowhisper
PHOWHISPER_URL=http://localhost:8001
TTS_PROVIDER=browser

# ═══════════════════════════════════════
# WebSocket Server
# ═══════════════════════════════════════
NEXT_PUBLIC_WS_URL="ws://localhost:3001"
WS_PORT=3001

# ═══════════════════════════════════════
# File Storage
# ═══════════════════════════════════════
UPLOAD_DIR="./data/uploads"
MAX_FILE_SIZE=5242880

# ═══════════════════════════════════════
# App
# ═══════════════════════════════════════
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_TTS_PROVIDER=browser
NEXT_PUBLIC_STT_FALLBACK=webspeech
