# ═══════════════════════════════════════
# SiHi - Environment Variables
# ═══════════════════════════════════════

# Database (REQUIRED)
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/sihi"

# NextAuth (REQUIRED)
NEXTAUTH_SECRET="generate-a-random-32-char-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# WebSocket JWT (REQUIRED - MUST be different from NEXTAUTH_SECRET)
WS_JWT_SECRET="generate-another-random-32-char-secret"

# ═══════════════════════════════════════
# AI Provider (REQUIRED)
# ═══════════════════════════════════════
AI_PROVIDER="gemini"
GEMINI_API_KEYS="your-gemini-api-key-1,your-gemini-api-key-2"
GEMINI_MODEL="gemini-3.1-flash-lite"
GEMINI_EMBEDDING_MODEL="text-embedding-004"

# OpenAI (OPTIONAL - stub only in MVP)
# OPENAI_API_KEY=""

# ═══════════════════════════════════════
# Email Provider
# ═══════════════════════════════════════
EMAIL_PROVIDER="mock"
# For production, use "resend":
# EMAIL_PROVIDER="resend"
# RESEND_API_KEY="re_xxx"
# EMAIL_FROM="SiHi <noreply@sihi.vn>"

# ═══════════════════════════════════════
# WebSocket & STT
# ═══════════════════════════════════════
WS_PORT=3001
STT_SERVICE_URL="http://localhost:8001"

# ═══════════════════════════════════════
# Public (exposed to browser)
# ═══════════════════════════════════════
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_WS_URL="ws://localhost:3001"
NEXT_PUBLIC_TTS_PROVIDER="browser"
NEXT_PUBLIC_STT_FALLBACK="webspeech"
