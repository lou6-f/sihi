# ═══════════════════════════════════════════════════════════════
# SiHi — Docker Environment Variables Template
# File này dùng cho docker-compose (ws-server + stt-service)
# Hướng dẫn: copy file này thành .env
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# WebSocket JWT Secret — REQUIRED
# PHẢI giống với WS_JWT_SECRET trong sihi/.env
# Tạo secret: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
WS_JWT_SECRET="<random-32-bytes-same-as-sihi-env>"
